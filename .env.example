# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Production auth/security
# Set to true in Cloud Run production. Keep false/empty for local development without Firebase credentials.
REQUIRE_AUTH="true"
IDENTITY_PLATFORM_PROJECT_ID="my-gcp-project-id"
ALLOWED_ORIGIN="https://itera-br.vercel.app"

# Google Sheets / Workspace under BAA
GOOGLE_SHEET_ID="MY_PRODUCTION_SHEET_ID"
# Recommended in Cloud Run: share the Google Sheet with the Cloud Run service account and use ADC.
GOOGLE_USE_ADC="true"
# Optional local/key-based fallback. Prefer Secret Manager if these are ever used.
GOOGLE_CLIENT_EMAIL="service-account@my-gcp-project-id.iam.gserviceaccount.com"
GOOGLE_PRIVATE_KEY="ONLY_IF_NOT_USING_ADC_STORE_IN_SECRET_MANAGER"

# Vercel frontend variables
VITE_API_BASE_URL="https://my-cloud-run-service-url"
VITE_FIREBASE_API_KEY="MY_FIREBASE_API_KEY"
VITE_FIREBASE_AUTH_DOMAIN="my-project.firebaseapp.com"
VITE_FIREBASE_PROJECT_ID="my-gcp-project-id"
VITE_FIREBASE_APP_ID="MY_FIREBASE_APP_ID"
